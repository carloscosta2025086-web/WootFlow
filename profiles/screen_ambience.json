{
  "name": "Screen Ambience",
  "description": "Captura e replica dinamicamente as cores do ecrã em tempo real",
  "trigger": [],
  "enabled": true,
  "mode": "cinematic",
  "fps": 60,
  "grid_size": 3,
  "color_sensitivity": "medium",
  "brightness": 1.0,
  "smoothing_factor": 0.5,
  "exclude_black": true,
  "black_threshold": 15,
  "exclude_white": false,
  "white_threshold": 220,
  "monitor_index": 0,
  "individual_brightness": {
    "enabled": true,
    "min_scale": 0.35,
    "max_scale": 1.85,
    "gamma": 0.72
  },
  "region_brightness": {
    "0": 1.0,
    "1": 1.05,
    "2": 1.0,
    "3": 0.95,
    "4": 1.2,
    "5": 1.0,
    "6": 0.9,
    "7": 1.0,
    "8": 0.9
  },
  "zones": [
    {
      "region": 0,
      "name": "Top-Left",
      "keys": ["ESC", "1", "2"],
      "description": "Canto superior esquerdo do ecrã"
    },
    {
      "region": 1,
      "name": "Top-Center",
      "keys": ["3", "4", "5", "6"],
      "description": "Topo central do ecrã"
    },
    {
      "region": 2,
      "name": "Top-Right",
      "keys": ["7", "8", "9", "0"],
      "description": "Canto superior direito do ecrã"
    },
    {
      "region": 3,
      "name": "Mid-Left",
      "keys": ["TAB", "Q", "A"],
      "description": "Lado esquerdo central do ecrã"
    },
    {
      "region": 4,
      "name": "Center",
      "keys": ["W", "S", "D", "E", "R", "F", "G", "H", "J", "K"],
      "description": "Centro do ecrã (zona principal)"
    },
    {
      "region": 5,
      "name": "Mid-Right",
      "keys": ["U", "I", "O", "P"],
      "description": "Lado direito central do ecrã"
    },
    {
      "region": 6,
      "name": "Bottom-Left",
      "keys": ["LSHIFT", "Z", "X", "LCTRL"],
      "description": "Canto inferior esquerdo do ecrã"
    },
    {
      "region": 7,
      "name": "Bottom-Center",
      "keys": ["C", "V", "B", "N", "M"],
      "description": "Base central do ecrã"
    },
    {
      "region": 8,
      "name": "Bottom-Right",
      "keys": [",", ".", "/", "RSHIFT"],
      "description": "Canto inferior direito do ecrã"
    }
  ],
  "animation": "screen_ambience",
  "fallback_color": [50, 50, 50],
  "update_interval_ms": 16,
  "presets": {
    "cinematic": {
      "description": "Modo suave para cinema/vídeos",
      "fps": 30,
      "smoothing_factor": 0.65,
      "color_sensitivity": "medium",
      "brightness": 0.9
    },
    "dynamic": {
      "description": "Modo dinâmico para conteúdo variado",
      "fps": 60,
      "smoothing_factor": 0.45,
      "color_sensitivity": "high",
      "brightness": 1.0
    },
    "gaming": {
      "description": "Modo gaming com resposta rápida",
      "fps": 120,
      "smoothing_factor": 0.25,
      "color_sensitivity": "high",
      "brightness": 1.2
    }
  }
}
