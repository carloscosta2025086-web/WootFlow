# -----------------------------
# Python
# -----------------------------
__pycache__/
*.py[cod]
*$py.class

# Virtual environments
.venv/
venv/
env/
ENV/

# Tool caches
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
.coverage.*
htmlcov/

# -----------------------------
# Build and packaging
# -----------------------------
build/
dist/
.artifacts/
installer/output/*
installer/prereqs/*.exe
*.egg-info/
*.spec.bak

# PyInstaller / binaries / logs
*.exe
*.dll
*.pyd
*.so
*.dylib
*.log

# -----------------------------
# Node / frontend
# -----------------------------
node_modules/
ui/node_modules/
ui/dist/
ui/.vite/
*.tsbuildinfo

# Package manager caches
.npm/
.pnpm-store/
.yarn/

# -----------------------------
# Editor / OS
# -----------------------------
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db

# Keep installer folder structure, ignore generated payloads.
!installer/output/.gitkeep
!installer/prereqs/.gitkeep
